rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Clients: leitura e escrita apenas para autenticados
    match /quote_clients/{clientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Services: leitura e escrita apenas para autenticados
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Materials: leitura e escrita apenas para autenticados
    match /materials/{materialId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Quotes: leitura e escrita apenas para autenticados
    match /quotes/{quoteId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Items subcollection: regras seguem a quote pai
      match /items/{itemId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
